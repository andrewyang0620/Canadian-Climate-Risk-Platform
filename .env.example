# --------------------------------------------------
# Project
# --------------------------------------------------
PROJECT_NAME=canadian-climate-risk-platform
ENVIRONMENT=local-dev

# --------------------------------------------------
# PostgreSQL / PostGIS serving database
# --------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=climate_risk
POSTGRES_USER=climate_user
POSTGRES_PASSWORD=change_me

# Local host connection
LOCAL_POSTGRES_HOST=localhost
LOCAL_POSTGRES_PORT=5432

# --------------------------------------------------
# Airflow metadata database
# --------------------------------------------------
AIRFLOW_POSTGRES_HOST=airflow-postgres
AIRFLOW_POSTGRES_PORT=5432
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# --------------------------------------------------
# Spark
# --------------------------------------------------
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2

# --------------------------------------------------
# Local lakehouse paths
# --------------------------------------------------
LOCAL_BRONZE_PATH=/opt/project/lakehouse/bronze
LOCAL_SILVER_PATH=/opt/project/lakehouse/silver
LOCAL_GOLD_PATH=/opt/project/lakehouse/gold
LOCAL_AUDIT_PATH=/opt/project/lakehouse/audit

# --------------------------------------------------
# Azure placeholders
# --------------------------------------------------
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER_BRONZE=bronze
AZURE_STORAGE_CONTAINER_SILVER=silver
AZURE_STORAGE_CONTAINER_GOLD=gold
AZURE_STORAGE_CONTAINER_AUDIT=audit